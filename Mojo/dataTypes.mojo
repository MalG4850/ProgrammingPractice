def main():
    print("\nThis program shows declaration and printing of various data types.\n\n", end = "")

    comptime pi: Float64 = 3.14159265358979323
    x: Int32 = 10
    y: Bool = True
    z: String = "Hello World!"

    print("pi = ", pi, "\nx = ", x, "\ny = ", y, "\nz = ", z, end = "\n\n")